from fastapi import FastAPI
import gradio as gr
from google import genai
import uvicorn

# ----------------------------
# Gemini API Configuration
# ----------------------------
API_KEY = "YOUR_GEMINI_API_KEY"

client = genai.Client(api_key=API_KEY)

MODEL = "gemini-2.5-flash"

# ----------------------------
# AI Functions
# ----------------------------

def ask_ai(prompt):
    if not prompt.strip():
        return "Please enter a prompt."

    try:
        response = client.models.generate_content(
            model=MODEL,
            contents=prompt
        )
        return response.text
    except Exception as e:
        return f"Error: {e}"


def summarize(text):
    prompt = f"""
Summarize the following text in simple points.

{text}
"""

    return ask_ai(prompt)


def generate_code(task, language):
    prompt = f"""
Generate {language} code for:

{task}

Explain the code.
"""
    return ask_ai(prompt)


def translate(text, language):
    prompt = f"""
Translate the following into {language}.

{text}
"""
    return ask_ai(prompt)


def grammar(text):
    prompt = f"""
Correct grammar and improve the following text.

{text}
"""
    return ask_ai(prompt)


# ----------------------------
# Gradio UI
# ----------------------------

with gr.Blocks(title="Multimodal AI Assistant") as demo:

    gr.Markdown(
        """
# 🤖 Multimodal AI Assistant

Built with:
- Gradio
- FastAPI
- Google Gemini
"""
    )

    with gr.Tab("💬 Chat"):

        chat_input = gr.Textbox(
            label="Ask Anything",
            lines=5
        )

        chat_output = gr.Textbox(
            label="Response",
            lines=10
        )

        gr.Button("Ask AI").click(
            ask_ai,
            chat_input,
            chat_output
        )

    with gr.Tab("📝 Summarizer"):

        summary_input = gr.Textbox(
            lines=10,
            label="Enter Text"
        )

        summary_output = gr.Textbox(
            lines=10,
            label="Summary"
        )

        gr.Button("Summarize").click(
            summarize,
            summary_input,
            summary_output
        )

    with gr.Tab("💻 Code Generator"):

        task = gr.Textbox(
            label="Describe Code"
        )

        language = gr.Dropdown(
            [
                "Python",
                "Java",
                "C",
                "C++",
                "JavaScript"
            ],
            value="Python",
            label="Language"
        )

        code_output = gr.Textbox(
            lines=15,
            label="Generated Code"
        )

        gr.Button("Generate").click(
            generate_code,
            [task, language],
            code_output
        )

    with gr.Tab("🌍 Translator"):

        translate_input = gr.Textbox(
            lines=8,
            label="Enter Text"
        )

        translate_lang = gr.Dropdown(
            [
                "Telugu",
                "Hindi",
                "Tamil",
                "French",
                "Spanish"
            ],
            value="Telugu",
            label="Language"
        )

        translate_output = gr.Textbox(
            lines=8,
            label="Translated Text"
        )

        gr.Button("Translate").click(
            translate,
            [translate_input, translate_lang],
            translate_output
        )

    with gr.Tab("✍ Grammar Checker"):

        grammar_input = gr.Textbox(
            lines=8,
            label="Enter Text"
        )

        grammar_output = gr.Textbox(
            lines=8,
            label="Corrected Text"
        )

        gr.Button("Correct").click(
            grammar,
            grammar_input,
            grammar_output
        )


# ----------------------------
# FastAPI
# ----------------------------

app = FastAPI()

app = gr.mount_gradio_app(app, demo, path="/")


@app.get("/health")
def health():
    return {"status": "Running"}


# ----------------------------
# Run Server
# ----------------------------

if __name__ == "__main__":
    uvicorn.run(app, host="127.0.0.1", port=8000)
